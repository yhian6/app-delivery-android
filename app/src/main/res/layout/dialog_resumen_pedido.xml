<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:padding="0dp"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@android:color/white">

        <!-- Encabezado amarillo -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#FFEB3B"
            android:orientation="vertical"
            android:gravity="center"
            android:padding="20dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Pedido realizado"
                android:textSize="20sp"
                android:textStyle="bold"
                android:textColor="@android:color/black"
                android:layout_marginBottom="4dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Gracias por tu pedido de Ola Marina"
                android:textSize="14sp"
                android:textColor="@android:color/black"/>
        </LinearLayout>

        <!-- Contenido -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Resumen del pedido"
                android:textSize="18sp"
                android:textStyle="bold"
                android:layout_marginBottom="12dp"/>

            <!-- Fecha -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Fecha de entrega"
                android:textSize="16sp"
                android:textStyle="bold"/>

            <TextView
                android:id="@+id/txtFechaEntrega"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="20/09/2025"
                android:textSize="15sp"
                android:layout_marginBottom="16dp"/>

            <!-- Mensaje verde -->
            <TextView
                android:id="@+id/txtAvisoAnulacion"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Si desea anular el pedido, vaya a Mis pedidos..."
                android:textSize="14sp"
                android:textColor="@color/green"
                android:layout_marginTop="6dp"
                android:layout_marginBottom="16dp"/>

            <!-- Dirección -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Dirección de entrega"
                android:textSize="16sp"
                android:textStyle="bold"/>

            <TextView
                android:id="@+id/txtDireccionEntrega"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Av. Principal 123, Piura"
                android:textSize="15sp"
                android:layout_marginBottom="16dp"/>

            <!-- Método de pago -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Pago"
                android:textSize="16sp"
                android:textStyle="bold"/>

            <TextView
                android:id="@+id/txtPago"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Yape"
                android:textSize="15sp"
                android:layout_marginBottom="16dp"/>

            <!-- Total -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Total"
                android:textSize="16sp"
                android:textStyle="bold"/>

            <TextView
                android:id="@+id/txtTotal"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="S/ 45.00"
                android:textSize="15sp"
                android:layout_marginBottom="20dp"/>

            <!-- Botón WhatsApp -->
        </LinearLayout>
    </LinearLayout>
</ScrollView>
