<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <androidx.appcompat.widget.Toolbar
            android:id="@+id/tbDetallePedidos"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@android:color/transparent"/>


        <!-- Encabezado bonito -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp"
            android:background="#F5F5F5"
            android:layout_marginBottom="12dp"
            android:elevation="2dp">

            <TextView
                android:id="@+id/txtFechaDetalle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/fecha_del_pedido"
                android:textColor="#444"
                android:textSize="14sp"/>

            <TextView
                android:id="@+id/valorFechaDetalle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/_23_de_julio_2025"
                android:textColor="#000"
                android:textSize="16sp"
                android:textStyle="bold"
                android:layout_marginBottom="8dp"/>

            <TextView
                android:id="@+id/txtTotalDetalle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/total"
                android:textColor="#444"
                android:textSize="14sp"/>

            <TextView
                android:id="@+id/valorTotalDetalle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="S/ 35.00"
                android:textColor="#000"
                android:textSize="16sp"
                android:textStyle="bold"
                android:layout_marginBottom="8dp"/>

            <TextView
                android:id="@+id/txtMetodoPago"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/m_todo_de_pago"
                android:textColor="#444"
                android:textSize="14sp"/>

            <TextView
                android:id="@+id/valorMetodoPago"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Yape"
                android:textColor="#000"
                android:textSize="16sp"
                android:textStyle="bold"/>
        </LinearLayout>

        <!-- Seguimiento visual del estado -->
        <LinearLayout
            android:id="@+id/layoutTracking"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:layout_marginBottom="16dp">

            <TextView
                android:id="@+id/pasoPendiente"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/pendiente"
                android:textColor="#999999"
                android:padding="8dp"
                android:textSize="14sp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="→"
                android:textSize="14sp"
                android:paddingHorizontal="4dp"/>

            <TextView
                android:id="@+id/pasoPreparando"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/preparando"
                android:textColor="#999999"
                android:padding="8dp"
                android:textSize="14sp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="→"
                android:textSize="14sp"
                android:paddingHorizontal="4dp"/>

            <TextView
                android:id="@+id/pasoEnCamino"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/en_camino"
                android:textColor="#999999"
                android:padding="8dp"
                android:textSize="14sp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="→"
                android:textSize="14sp"
                android:paddingHorizontal="4dp"/>

            <TextView
                android:id="@+id/pasoEntregado"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/entregado"
                android:textColor="#999999"
                android:padding="8dp"
                android:textSize="14sp"/>
        </LinearLayout>

        <!-- Lista de productos del pedido -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/recyclerDetallePedido"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:nestedScrollingEnabled="false"/>

        <Button
            android:id="@+id/btnVerComprobante"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Ver comprobante"
            android:visibility="gone"
            android:layout_marginTop="16dp"/>

    </LinearLayout>
</androidx.core.widget.NestedScrollView>
