<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <!-- Toolbar -->
        <androidx.appcompat.widget.Toolbar
            android:id="@+id/toolbarPerfil"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            android:background="@android:color/transparent"
            app:title=""
            app:contentInsetStartWithNavigation="0dp"/>

        <!-- Foto de perfil circular -->
        <com.google.android.material.imageview.ShapeableImageView
            android:id="@+id/imgPerfil"
            android:layout_width="120dp"
            android:layout_height="120dp"
            android:layout_gravity="center"
            android:src="@drawable/user"
            app:shapeAppearanceOverlay="@style/CircularShape"
            android:layout_marginTop="16dp"/>

        <!-- Mensaje informativo -->
        <TextView
            android:id="@+id/tvInfoFoto"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Al cambiar tu foto, solo tú podrás verla."
            android:textSize="12sp"
            android:textColor="@color/black"
            android:layout_gravity="center"
            android:layout_marginTop="8dp"
            android:gravity="center"
            android:paddingHorizontal="16dp"/>

        <!-- Nombre y correo -->
        <TextView
            android:id="@+id/tvNombre"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Nombre Apellido"
            android:textSize="20sp"
            android:textStyle="bold"
            android:layout_gravity="center"
            android:layout_marginTop="12dp"/>

        <TextView
            android:id="@+id/tvCorreo"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="correo@ejemplo.com"
            android:textSize="14sp"
            android:textColor="@color/cardview_dark_background"
            android:layout_gravity="center"/>

        <!-- Opciones -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:radius="12dp"
            app:cardElevation="4dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:id="@+id/btnEditarPerfil"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:drawablePadding="10dp"
                    android:padding="12dp"
                    android:drawableEnd="@drawable/ic_edit"
                    android:text="Editar perfil"
                    android:textSize="16sp"
                    android:background="?android:attr/selectableItemBackground"
                    android:clickable="true"/>

                <TextView
                    android:id="@+id/btnCambiarContrasena"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:drawablePadding="10dp"
                    android:padding="12dp"
                    android:text="Cambiar contraseña"
                    android:drawableEnd="@drawable/ic_password"
                    android:textSize="16sp"
                    android:background="?android:attr/selectableItemBackground"
                    android:clickable="true"/>

                <TextView
                    android:id="@+id/btnCerrarSesion"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:drawablePadding="10dp"
                    android:padding="12dp"
                    android:text="Cerrar sesión"
                    android:drawableEnd="@drawable/ic_out"
                    android:textSize="16sp"
                    android:background="?android:attr/selectableItemBackground"
                    android:textColor="@color/black"
                    android:clickable="true"/>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

    </LinearLayout>
</ScrollView>
